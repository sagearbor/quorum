# ============================================================
# apps/web — NEXT_PUBLIC environment variables
# ============================================================
# Copy to .env.local or run: bash scripts/setup-web-env.sh
# to auto-generate from the root .env file.
# ============================================================

# === Supabase (required for production) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === API ===
# Backend URL. Defaults to http://localhost:8000 if unset.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# === Demo / Test Mode ===
# Set to "true" to use mock data instead of Supabase.
# When false or unset, zero mock data is used.
# NEXT_PUBLIC_QUORUM_TEST_MODE=false

# === Avatar ===
# Provider: mock | elevenlabs | simli (omit for no TTS provider)
# NEXT_PUBLIC_AVATAR_PROVIDER=
# Set to "true" to enable avatar mock mode (emotion cycling, mock gaze).
# When false or unset, requires real MediaPipe / webcam.
# NEXT_PUBLIC_AVATAR_MOCK=false

# ElevenLabs (only if NEXT_PUBLIC_AVATAR_PROVIDER=elevenlabs)
# NEXT_PUBLIC_ELEVENLABS_API_KEY=
# NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Simli (only if NEXT_PUBLIC_AVATAR_PROVIDER=simli)
# NEXT_PUBLIC_SIMLI_API_KEY=

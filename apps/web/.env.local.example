# apps/web/.env.local.example
# Copy to .env.local and fill in values, or run: scripts/setup-web-env.sh
# to auto-populate from the root .env file.

# --- Supabase (required for live mode) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- API server ---
# Defaults to http://localhost:8000 if unset
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Demo / test mode ---
# Set to "true" to use in-memory mock data instead of Supabase
NEXT_PUBLIC_QUORUM_TEST_MODE=false

# --- Avatar system ---
# Set to "true" to use mock emotion/vision data (no webcam needed)
NEXT_PUBLIC_AVATAR_MOCK=false
# Avatar TTS provider: "elevenlabs" | "simli" | "" (browser SpeechSynthesis)
NEXT_PUBLIC_AVATAR_PROVIDER=

# --- Avatar provider keys (only needed if provider is set) ---
NEXT_PUBLIC_ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
NEXT_PUBLIC_SIMLI_API_KEY=

# apps/web/.env.local.example
# ---------------------------------------------------------
# Copy this file to .env.local, or run: bash scripts/setup-web-env.sh
# to auto-generate .env.local from the root .env file.
# ---------------------------------------------------------

# Supabase (required for live mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API (defaults to http://localhost:8000 if unset)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Demo / test mode — when "true", frontend uses mockStream instead of Supabase.
# Only set this explicitly; when unset or "false", zero mock data is used.
NEXT_PUBLIC_QUORUM_TEST_MODE=false

# Avatar mock mode — when "true", EmotionDetector and VisionTracker use
# synthetic data (sine-wave gaze, emotion cycling) instead of MediaPipe.
# When unset or "false", real webcam + MediaPipe is required.
NEXT_PUBLIC_AVATAR_MOCK=false

# Avatar TTS provider — "elevenlabs" | "simli" | "" (empty = browser SpeechSynthesis fallback)
NEXT_PUBLIC_AVATAR_PROVIDER=

# ElevenLabs credentials (only needed when NEXT_PUBLIC_AVATAR_PROVIDER=elevenlabs)
NEXT_PUBLIC_ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Simli credentials (only needed when NEXT_PUBLIC_AVATAR_PROVIDER=simli)
NEXT_PUBLIC_SIMLI_API_KEY=

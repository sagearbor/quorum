# =============================================================================
# Quorum — Environment Variables
# =============================================================================
# Copy this file to .env (backend) and use values for apps/web/.env.local too.
# See docs/SETUP.md for step-by-step instructions.
#
# NOTE: This file is named .example.env (not .env.example) so tooling
# that ignores .env* patterns can still read it.

# -----------------------------------------------------------------------------
# Supabase (backend — .env at repo root, loaded by python-dotenv)
# Run `supabase status` to get these values for local dev
# -----------------------------------------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<from supabase status>
SUPABASE_SERVICE_KEY=<from supabase status>

# -----------------------------------------------------------------------------
# Supabase (frontend — copy to apps/web/.env.local)
# NEXT_PUBLIC_ prefix required for browser access
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<same anon key>

# -----------------------------------------------------------------------------
# Frontend → Backend connection (copy to apps/web/.env.local)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Azure OpenAI (DCRI ai-sandbox-instance)
# Managed Identity is the default — uses your `az login` credentials.
# Set AZURE_OPENAI_USE_MANAGED_IDENTITY=false + AZURE_OPENAI_KEY to use API key.
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://ai-sandbox-instance.openai.azure.com/
AZURE_OPENAI_KEY=                             # only needed if managed identity disabled
AZURE_OPENAI_DEPLOYMENT_T2=gpt-4o-mini       # Tier 2: conflict detection
AZURE_OPENAI_DEPLOYMENT_T3=gpt-4o            # Tier 3: artifact synthesis
AZURE_OPENAI_USE_MANAGED_IDENTITY=true

# -----------------------------------------------------------------------------
# LLM provider selection
# -----------------------------------------------------------------------------
QUORUM_LLM_PROVIDER=azure                    # azure | anthropic | mock

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=                              # generate: openssl rand -base64 32

# -----------------------------------------------------------------------------
# Demo / Test mode (skips all external services)
# -----------------------------------------------------------------------------
# QUORUM_TEST_MODE=true                       # backend: uses MockLLMProvider
# NEXT_PUBLIC_QUORUM_TEST_MODE=true           # frontend: uses DemoEngine

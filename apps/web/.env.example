# Supabase (NEXT_PUBLIC_ prefix exposes to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Demo mode — set to "true" for fully offline demo (no backend, no API key)
# Also activates automatically when NEXT_PUBLIC_SUPABASE_URL is not set
# NEXT_PUBLIC_QUORUM_TEST_MODE=true

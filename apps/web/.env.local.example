# Quorum Web — Environment Variables
# Copy to .env.local or run: scripts/setup-web-env.sh

# --- Required ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Optional ---
# Backend API URL (defaults to http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Demo/test mode — uses mock data streams instead of Supabase
NEXT_PUBLIC_QUORUM_TEST_MODE=false

# Avatar provider: "elevenlabs" | "simli" | "" (empty = no TTS provider)
NEXT_PUBLIC_AVATAR_PROVIDER=
NEXT_PUBLIC_AVATAR_MOCK=false

# Provider API keys (only needed if avatar provider is configured)
NEXT_PUBLIC_ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
NEXT_PUBLIC_SIMLI_API_KEY=

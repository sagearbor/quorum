# Quorum Web — Environment Variables
# Copy to .env.local and fill in values, OR run: scripts/setup-web-env.sh
#
# The setup script reads from root .env and maps vars automatically:
#   SUPABASE_URL        → NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_ANON_KEY   → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   QUORUM_TEST_MODE    → NEXT_PUBLIC_QUORUM_TEST_MODE
#   API_URL             → NEXT_PUBLIC_API_URL
#   AVATAR_MOCK         → NEXT_PUBLIC_AVATAR_MOCK

# --- Required ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- API ---
# Backend API URL (defaults to http://127.0.0.1:9000 in setup script)
NEXT_PUBLIC_API_URL=http://127.0.0.1:9000

# --- Mode flags ---
# Demo/test mode — uses mock data streams instead of Supabase (default: false)
NEXT_PUBLIC_QUORUM_TEST_MODE=false

# Avatar mock mode — cycles through fake emotions instead of using MediaPipe (default: false)
NEXT_PUBLIC_AVATAR_MOCK=false

# --- Avatar provider (optional) ---
# Provider: "elevenlabs" | "simli" | "" (empty = no TTS, browser Speech Synthesis fallback)
NEXT_PUBLIC_AVATAR_PROVIDER=

# Only needed if avatar provider is configured:
NEXT_PUBLIC_ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
NEXT_PUBLIC_SIMLI_API_KEY=

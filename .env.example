# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_T2=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_T3=gpt-4o

# Database provider: "supabase" (default) or "azure"
DB_PROVIDER=supabase

# Supabase (used when DB_PROVIDER=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Azure SQL (used when DB_PROVIDER=azure)
# AZURE_SQL_CONNECTION_STRING=mssql+pyodbc://user:pass@server/db?driver=ODBC+Driver+18+for+SQL+Server

# Anthropic (alternative LLM provider)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_T2=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_T3=claude-sonnet-4-6

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Frontend realtime provider: omit for Supabase realtime, "polling" for Azure SQL
# NEXT_PUBLIC_REALTIME_PROVIDER=polling
# NEXT_PUBLIC_API_URL=http://localhost:8000

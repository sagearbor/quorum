# ============================================================
# Quorum — Environment Configuration
# ============================================================
# Copy to .env and uncomment/fill what you need.
# Defaults are set for fully-local operation (no cloud accounts).
# ============================================================

# === STORAGE ===
# STORAGE_PROVIDER=local              # local | azure_blob
# AZURE_STORAGE_ACCOUNT=              # required for azure_blob
# AZURE_STORAGE_CONTAINER=quorum-files
# AZURE_STORAGE_CONNECTION_STRING=    # optional: for local dev against Azurite

# === DATABASE ===
# DATABASE_PROVIDER=supabase          # supabase | postgres
# --- supabase (default) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# --- postgres (alternative — any Postgres instance) ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/quorum

# === LLM ===
# QUORUM_LLM_PROVIDER=openai          # openai | azure | anthropic | local | mock
# --- openai (default) ---
OPENAI_API_KEY=
# OPENAI_MODEL_T2=gpt-4o-mini
# OPENAI_MODEL_T3=gpt-4o
# --- azure ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=                   # omit to use Managed Identity (DefaultAzureCredential)
# AZURE_OPENAI_DEPLOYMENT_T2=gpt-4o-mini
# AZURE_OPENAI_DEPLOYMENT_T3=gpt-4o
# --- anthropic ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_T2=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_T3=claude-sonnet-4-6
# --- local (Ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3

# === COORDINATION ===
# COORDINATION_BACKEND=supabase       # supabase | a2a

# === AVATAR ===
# AVATAR_PROVIDER=mock                # mock | elevenlabs | simli
# AVATAR_MOCK=true

# === TESTING ===
# QUORUM_TEST_MODE=true               # zero API cost, mock LLM responses

# === AUTH ===
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
